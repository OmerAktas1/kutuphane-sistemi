{
  "name": "kutuphane",
  "version": "1.0.0",
  "description": "Kutuphane Takip Sistemi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Kutuphane",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.kutuphane.app",
    "productName": "KutuphaneTakip",
    "asar": false,
    "directories": {
      "output": "output"
    },
    "files": [
      "main.js",
      "preload.js",
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/prisma",
        "to": "backend/prisma",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/.env",
        "to": "backend/.env"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "dir"
    },
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
